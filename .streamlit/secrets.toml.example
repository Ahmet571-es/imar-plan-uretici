# Streamlit Cloud: Settings > Secrets kısmına aşağıdaki içeriği yapıştırın.
# Lokal: Bu dosyayı .streamlit/secrets.toml olarak kopyalayın.

# ── AI API Anahtarları (opsiyonel — AI plan üretimi için) ──
ANTHROPIC_API_KEY = "sk-ant-..."
XAI_API_KEY = "xai-..."

# ── Supabase PostgreSQL (CRM kalıcı veritabanı) ──
# Supabase > Project Settings > Database > Connection string (URI)
# Transaction pooler (port 6543) kullanın.
SUPABASE_DB_URL = "postgresql://postgres.[ref]:[sifre]@aws-0-[region].pooler.supabase.com:6543/postgres"
